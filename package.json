{
  "name": "@vibecontrols/vibe-plugin-security",
  "version": "2026.521.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Security lifecycle orchestrator — dispatches to per-stage security providers (secrets, sbom, release-gate, etc.).",
  "engines": {
    "bun": ">=1.3.14"
  },
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./tool-installer": {
      "import": "./dist/tool-installer.js",
      "types": "./dist/tool-installer.d.ts"
    },
    "./fingerprint": {
      "import": "./dist/fingerprint.js",
      "types": "./dist/fingerprint.d.ts"
    },
    "./normalizer": {
      "import": "./dist/normalizer.js",
      "types": "./dist/normalizer.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/types.ts ./src/tool-installer.ts ./src/fingerprint.ts ./src/normalizer.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "dev": "tsc --watch",
    "lint": "eslint ./src ./tests",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test ./tests",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run test && bun run build"
  },
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.509.2",
    "elysia": "^1.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@vibecontrols/agent": ">=2026.428.0"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    }
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "security",
    "sast",
    "sca",
    "sbom",
    "secrets",
    "policy",
    "opa",
    "supply-chain",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-security.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-security/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ]
}
